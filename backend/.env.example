# Environment Variables — HANARA Schools SMS Backend
# Copy this file to .env and fill in your values before running.

# Server
NODE_ENV=development
PORT=5000

# MongoDB — Atlas URI or local
MONGODB_URI=mongodb://localhost:27017/hanara_sms

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — frontend origin (no trailing slash)
CLIENT_ORIGIN=http://localhost:5173

# Seed defaults (optional overrides)
SEED_ADMIN_EMAIL=admin@hanaraschools.edu.gh
SEED_ADMIN_PASSWORD=Admin@2026
