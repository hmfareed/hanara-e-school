# ============================================================
# HANARA SMS – Docker Environment Variables
# ============================================================
# 1. Copy this file to .env  →  cp .env.example .env
# 2. Fill in the required values marked with  ← CHANGE THIS
# 3. Run: docker compose up --build
# ============================================================

# ── MongoDB ───────────────────────────────────────────────
MONGO_ROOT_USER=hanara
MONGO_ROOT_PASSWORD=hanaraSecret2026   # ← CHANGE THIS in production

# ── Backend / JWT ─────────────────────────────────────────
# MUST be long, random strings – generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_min_64_chars    # ← CHANGE THIS
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_min_64_chars  # ← CHANGE THIS

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Seeded Admin Account ──────────────────────────────────
SEED_ADMIN_EMAIL=admin@hanaraschools.edu.gh
SEED_ADMIN_PASSWORD=Admin@2026    # ← CHANGE THIS in production

# ── Frontend / CORS ───────────────────────────────────────
# Update to your server's public domain/IP when deploying to the internet
CLIENT_ORIGIN=http://localhost

# ── Ports ─────────────────────────────────────────────────
FRONTEND_PORT=80    # The port the app will be available on the host
